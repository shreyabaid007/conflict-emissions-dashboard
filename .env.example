# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic Claude API (direct)
WCED_ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (alternative to direct Anthropic — set one or the other)
# Register at: https://openrouter.ai/keys
# WCED_OPENROUTER_API_KEY=sk-or-...

# AI provider: "anthropic" (default) or "openrouter"
# When set to "openrouter", the SDK talks to OpenRouter instead of Anthropic directly.
# If only OPENROUTER_API_KEY is set (no ANTHROPIC_API_KEY), openrouter is used automatically.
# WCED_AI_PROVIDER=anthropic

# Custom base URL override (optional — normally auto-detected from provider)
# WCED_AI_BASE_URL=

# NASA FIRMS (Fire Information for Resource Management System)
# Register at: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your-firms-map-key

# ACLED (Armed Conflict Location & Event Data — preferred, requires approved account)
# Register at: https://acleddata.com/register/
ACLED_EMAIL=
ACLED_PASSWORD=

# GDELT (no auth needed, used as fallback when ACLED unavailable)
# Conflict source selection: "acled", "gdelt", or "both"
# Default (unset): try ACLED first, fall back to GDELT on 403 or missing creds
WCED_CONFLICT_SOURCE=gdelt

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://wced:password@localhost:5432/wced

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=wced-rasters

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=wced-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# App
WCED_ENVIRONMENT=development
WCED_METHODOLOGY_VERSION=1.0
WCED_LOG_LEVEL=INFO
