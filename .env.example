# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# NASA FIRMS (Fire Information for Resource Management System)
# Register at: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your-firms-map-key

# ACLED (Armed Conflict Location & Event Data)
# Register at: https://acleddata.com/register/
ACLED_API_KEY=your-acled-api-key
ACLED_EMAIL=your-email@example.com

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://wced:password@localhost:5432/wced

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=wced-rasters

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Sentry (optional)
SENTRY_DSN=

# App
WCED_ENVIRONMENT=development
WCED_METHODOLOGY_VERSION=1.0
